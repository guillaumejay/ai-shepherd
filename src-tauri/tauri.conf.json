{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Shepherd",
  "version": "0.1.0",
  "identifier": "com.github.aishepherd.desktop",
  "build": {
    "beforeDevCommand": "pnpm exec vite",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      { "title": "AI Shepherd", "width": 1100, "height": 800 }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
